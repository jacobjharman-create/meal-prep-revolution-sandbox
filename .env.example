# Optional local fallback. Prefer macOS Keychain for secrets.
# OPENAI_API_KEY=sk-...
# Required on the server for AI meal preview generation.
# OPENAI_IMAGE_MODEL=gpt-image-2
# Smallest 16:10 generation size that clears OpenAI's current pixel minimum.
# Both numbers must be divisible by 16.
# OPENAI_MEAL_GENERATION_SIZE=1296x816
# Saved cart preview size after local compression/downscaling.
# OPENAI_MEAL_PREVIEW_SIZE=768x480
# OPENAI_IMAGE_QUALITY=medium
# OPENAI_IMAGE_COMPRESSION=82
